# ============================================================
# AREPA SMASH LOVERS - Environment Variables Template
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================================

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- SUPABASE STAGING (para testing) ---
# NEXT_PUBLIC_SUPABASE_URL=https://staging-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=staging_anon_key

# --- KDS WEBHOOK ---
KDS_WEBHOOK_SECRET=your_webhook_secret_here

# --- SEDES / BRANDS ---
SEDE_AREPA_ID=uuid-de-arepa-lovers
SEDE_SMASH_ID=uuid-de-smash-lovers

# --- MIO PAYMENT GATEWAY ---
MIO_API_KEY=your_mio_api_key
MIO_API_SECRET=your_mio_api_secret
MIO_API_URL=https://api.mio.com.do/v1

# --- WHATSAPP / TWILIO (para notificaciones) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# --- PEDIDOSYA INTEGRATION ---
PEDIDOSYA_API_KEY=your_pedidosya_key
PEDIDOSYA_RESTAURANT_ID=your_restaurant_id

# --- CLOUDINARY (fotos productos) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SENTRY (error tracking) ---
SENTRY_DSN=https://your@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project
